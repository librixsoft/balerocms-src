RewriteEngine On

# 1) Bloquear acceso a carpetas internas
RewriteRule ^(Framework|Modules|resources|vendor|tests|node_modules)/ - [F,L]

# 2) Permitir todo dentro de /public/
RewriteRule ^public/ - [L]

# 3) Permitir la raíz (/) y index.php
RewriteRule ^$ - [L]
RewriteRule ^index\.php$ - [L]

# 4) Rutas limpias: /module y /module/target
RewriteRule ^([a-zA-Z0-9_-]+)$ index.php?module=$1 [QSA,L]
RewriteRule ^([a-zA-Z0-9_-]+)/(.*)$ index.php?module=$1&target=$2 [QSA,L]

# 5) Bloquear todo lo demás
RewriteRule ^ - [F,L]
