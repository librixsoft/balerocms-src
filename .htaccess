Options +FollowSymLinks
RewriteEngine On

# Desactiva "Index Of /"
Options -Indexes
IndexIgnore *

# :::::::::::::::::::::
# :: Activos públicos ::
# :::::::::::::::::::::
RewriteRule ^assets/(.*)$ public/assets/$1 [L]

# :::::::::::::::::::::::::::::::::
# :: Continuar solo si NO es archivo real o carpeta ::
# :::::::::::::::::::::::::::::::::
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# :::::::::::::::::::::::::::::::
# :: Routing vía index.php ::
# :::::::::::::::::::::::::::::::

# /modulo → index.php?app=modulo
RewriteRule ^([a-zA-Z0-9_-]+)$ index.php?app=$1 [L]

# /modulo/sr → index.php?app=modulo&sr=lo-que-sea
RewriteRule ^([a-zA-Z0-9_-]+)/(.*)$ index.php?app=$1&sr=$2 [L]
