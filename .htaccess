RewriteEngine On

# Bloquear acceso web a carpetas internas
RewriteRule ^(Framework|Modules|resources|vendor|tests|node_modules)/ - [F,L]

# Permitir solo index.php en la raíz
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_URI} !/index\.php$ [NC]
RewriteRule ^ - [F,L]

# No reescribir si es index.php o carpeta real
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rutas limpias: /module y /module/target
RewriteRule ^([a-zA-Z0-9_-]+)$ index.php?module=$1 [QSA,L]
RewriteRule ^([a-zA-Z0-9_-]+)/(.*)$ index.php?module=$1&target=$2 [QSA,L]
