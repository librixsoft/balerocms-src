RewriteEngine On
Options -Indexes

# Bloquear acceso directo a index.php si se entra por /public/
RewriteCond %{THE_REQUEST} /public/index\.php [NC]
RewriteRule ^ - [F,L]

# Permitir assets
RewriteRule ^assets/ - [L]

# Permitir index.php solo cuando es llamado desde la raíz (vía rewrite)
RewriteRule ^index\.php$ - [L]

# Bloquear todo lo demás
RewriteRule ^ - [F,L]
